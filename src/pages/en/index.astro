---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Axsetra KB | Security, Banking Software & Digital Assets"
  description="Axsetra KB builds secure internet banking platforms (AXSE), VPS hardening, private no-logs VPN solutions, and blockchain products including token launches and crypto exchange development."
  lang="en"
>
  <Fragment slot="subtitle">Personal · Security · Finance · Digital Assets</Fragment>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="hero-content">
      <div class="container-fluid px-4 px-md-5">
        <div class="row align-items-center" style="min-height:100%;">
          <div class="col-12 col-lg-7 col-xl-6">
            <h1 class="hero-title axsetrakbfont titlecolor mb-2">Axsetra KB</h1>
            <h2 class="h4 subtitlecolor mb-3" style="letter-spacing:.02em;">Personal · Security · Finance · Digital Assets</h2>
            <p class="hero-lead subtitlecolor mb-4">
              Axsetra KB builds secure financial software and privacy-focused infrastructure: internet banking platforms (AXSE),
              VPS hardening, dedicated no-logs VPN, and blockchain solutions for tokens and exchanges.
            </p>
            <div class="d-flex flex-wrap gap-2">
              <a href="#services" class="btn btn-light px-4">Explore Services</a>
              <a href="#contact" class="btn btn-outline-light px-4">Contact</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="ad-slot">Ad Space - Google AdSense</div>

  <!-- SERVICES -->
  <section id="services" class="container py-5">
    <div class="row mb-4">
      <div class="col-lg-9">
        <h2 class="axsetrakbfont mb-2">Services</h2>
        <p class="text-muted mb-0">Secure-by-design development for banks, fintechs and private clients: web platforms, internet banking (AXSE), infrastructure security, private VPN, and blockchain products.</p>
      </div>
    </div>
    <div class="row g-4">
      <div class="col-12 col-md-6 col-xl-4">
        <div class="card service-card h-100">
          <div class="service-media service-media-icon"><div class="service-icon" aria-hidden="true">&#x1F310;</div></div>
          <div class="card-body">
            <h3 class="h5 card-title">Secure Web Platforms &amp; Integrations</h3>
            <p class="card-text text-muted">High-end websites and multilingual platforms with Python integrations for complex business needs.</p>
            <a href="#contact" class="btn btn-primary btn-sm">Details</a>
          </div>
        </div>
      </div>
      <div class="col-12 col-md-6 col-xl-4">
        <div class="card service-card h-100">
          <div class="service-media service-media-icon"><div class="service-icon" aria-hidden="true">&#x1F3E6;</div></div>
          <div class="card-body">
            <h3 class="h5 card-title">Internet Banking Software (AXSE)</h3>
            <p class="card-text text-muted">Production-ready internet banking software for banks and fintechs: accounts, payments, security, compliance.</p>
            <a href="#contact" class="btn btn-primary btn-sm">Details</a>
          </div>
        </div>
      </div>
      <div class="col-12 col-md-6 col-xl-4">
        <div class="card service-card h-100">
          <div class="service-media service-media-icon"><div class="service-icon" aria-hidden="true">&#x1F510;</div></div>
          <div class="card-body">
            <h3 class="h5 card-title">VPS Hardening &amp; Infrastructure Security</h3>
            <p class="card-text text-muted">Hardened environments: isolation, encryption, access control, and secure operations.</p>
            <a href="#contact" class="btn btn-primary btn-sm">Details</a>
          </div>
        </div>
      </div>
      <div class="col-12 col-md-6 col-xl-4">
        <div class="card service-card h-100">
          <div class="service-media service-media-icon"><div class="service-icon" aria-hidden="true">&#x1F6E1;&#xFE0F;</div></div>
          <div class="card-body">
            <h3 class="h5 card-title">Dedicated Private VPN (No-Logs)</h3>
            <p class="card-text text-muted">Dedicated high-speed VPN with custom exit country. Not shared with other clients. Anti-surveillance focus.</p>
            <a href="#contact" class="btn btn-primary btn-sm">Details</a>
          </div>
        </div>
      </div>
      <div class="col-12 col-md-6 col-xl-4">
        <div class="card service-card h-100">
          <div class="service-media service-media-icon"><div class="service-icon" aria-hidden="true">&#x1FA99;</div></div>
          <div class="card-body">
            <h3 class="h5 card-title">Token Development &amp; Launch</h3>
            <p class="card-text text-muted">Token creation and deployment on ETH, BNB Chain, and Solana with launch support and on-chain setup.</p>
            <a href="#contact" class="btn btn-primary btn-sm">Details</a>
          </div>
        </div>
      </div>
      <div class="col-12 col-md-6 col-xl-4">
        <div class="card service-card h-100">
          <div class="service-media service-media-icon"><div class="service-icon" aria-hidden="true">&#x1F501;</div></div>
          <div class="card-body">
            <h3 class="h5 card-title">Crypto Exchange Development (DEX/CEX)</h3>
            <p class="card-text text-muted">Exchange systems integrated with AXSE or standalone: trading, wallets, integrations, and secure backend logic.</p>
            <a href="#contact" class="btn btn-primary btn-sm">Details</a>
          </div>
        </div>
      </div>
      <div class="col-12 col-md-6 col-xl-4">
        <div class="card service-card h-100">
          <div class="service-media service-media-icon"><div class="service-icon" aria-hidden="true">&#x1F30D;</div></div>
          <div class="card-body">
            <h3 class="h5 card-title">Privacy Domain &amp; Web Identity Setup</h3>
            <p class="card-text text-muted">Domain and web identity setups with enhanced privacy, reduced exposure, and jurisdiction-aware configuration.</p>
            <a href="#contact" class="btn btn-primary btn-sm">Details</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="ad-slot">Ad Space - Google AdSense</div>

  <!-- CONTACT -->
  <section id="contact" class="container pb-5">
    <div class="card p-4 contact-card">
      <div class="row g-4 align-items-start">
        <div class="col-12 col-lg-5">
          <h2 class="axsetrakbfont mb-2">Contact</h2>
          <p class="text-muted mb-3">Describe what you need (high-level is enough). We will reply with a secure architecture proposal and next steps.</p>
          <div class="small text-muted">
            Email: axsetrakb@proton.me
          </div>
        </div>
        <div class="col-12 col-lg-7">
          <form id="contactForm" class="needs-validation" novalidate>
            <div class="row g-3">
              <div class="col-12 col-md-6">
                <label class="form-label" for="id_name">Name</label>
                <input id="id_name" name="name" class="form-control" required maxlength="120" placeholder="Your name" autocomplete="name" />
                <div class="invalid-feedback">Please enter your name.</div>
              </div>
              <div class="col-12 col-md-6">
                <label class="form-label" for="id_email">Email</label>
                <input id="id_email" name="email" type="email" class="form-control" required maxlength="180" placeholder="you@company.com" autocomplete="email" />
                <div class="invalid-feedback">Please enter a valid email.</div>
              </div>
              <div class="col-12">
                <label class="form-label" for="id_message">Message</label>
                <textarea id="id_message" name="message" class="form-control" rows="5" required maxlength="4000"
                  placeholder="Tell us what you want to build / secure, timeframe, and any key constraints."
                  autocomplete="off"></textarea>
                <div class="invalid-feedback">Please write a short message.</div>
              </div>
              <div class="col-12">
                <div class="d-flex flex-wrap gap-2 align-items-center">
                  <button type="submit" class="btn btn-primary px-4">Send message</button>
                  <small class="text-muted">We'll reply after a quick review.</small>
                </div>
                <div class="mt-2">
                  <small class="text-muted">
                    Important: we reply from <strong>axsetrakb@proton.me</strong>.
                    Please add it to your safe senders / whitelist to avoid missing our response.
                  </small>
                </div>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>

  <div class="ad-slot">Ad Space - Google AdSense</div>
</BaseLayout>
